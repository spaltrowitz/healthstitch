WHOOP_CLIENT_ID=your_whoop_client_id
WHOOP_CLIENT_SECRET=your_whoop_client_secret
WHOOP_REDIRECT_URI=http://localhost:3000/api/whoop/callback
JWT_SECRET=replace_with_secure_secret
BACKEND_URL=http://localhost:3000
PORT=3000
DATABASE_URL=postgresql://localhost:5432/healthstitch
FRONTEND_URL=http://localhost:5173

# Frontend: backend origin for API calls (used by Vite/React).
# Leave blank for local dev (Vite proxy handles it).
# Set to your Cloudflare Tunnel URL (e.g. https://xxx.trycloudflare.com) for remote access.
VITE_API_URL=
